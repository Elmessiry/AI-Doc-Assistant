# Copy to .env.test.local (gitignored) for local E2E runs, or set these as
# GitHub Actions secrets for CI. The NEXT_PUBLIC_* + OPENROUTER values already
# live in .env.local for local runs; they are repeated here only to document
# the full set the E2E test needs.

# Supabase project (same as the app uses)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Service-role key — used ONLY by the test to provision + clean up the test
# user. Never expose this to the app/browser. Supabase dashboard → Project
# Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Dedicated E2E user credentials (any email/password; the test creates it).
E2E_TEST_EMAIL=e2e@example.com
E2E_TEST_PASSWORD=<a-strong-password>

# Needed at runtime so the chat step can call the model.
OPENROUTER_API_KEY=<openrouter-key>
