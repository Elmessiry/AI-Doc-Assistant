# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but keep example templates (no secrets) tracked
!.env*.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Sentry Config File
.env.sentry-build-plugin
.env.local

# Local agent config / wizard artifacts
.claude/
CLAUDE.md
AGENTS.md
posthog-setup-report.md

# testing (Playwright — added Day 6)
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
# seeded auth session (contains real tokens — never commit)
/e2e/.auth/

# IDE / editor
.idea/
*.swp
